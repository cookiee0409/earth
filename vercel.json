{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "functions": {
    "api/live.js": { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/(countries-110m|routes|daily).json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
